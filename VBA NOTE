14. Dictionary主要用于去重
Set dict = CreateObject("Scripting.Dictionary") '大小写必须一模一样
For i = 4 to 21
  k = Cells(1,2)
  If dict.exists(k) Then
    dict.Item(k) = dict.Item(k) + Cells(i,4).Value	
  Else
    dict.Add k, Cells(i, 4).Value
  End If
Next i

